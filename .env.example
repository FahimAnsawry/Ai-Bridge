# ── Proxy server bind settings ────────────────────────────────
# HOST: interface to bind the proxy server on.
#   Use 0.0.0.0 to accept connections from any network interface (required for Docker/VPS).
#   Use 127.0.0.1 for local-only access (default).
HOST=0.0.0.0

# PUBLIC_HOST: the publicly reachable hostname or IP shown in startup logs.
#   Set this to your server's public IP or domain name.
PUBLIC_HOST=localhost

# PORT: port for the AI proxy (OpenAI-compatible /v1 endpoint).
PORT=3000

# WEB_PORT: port for the dashboard web UI.
#   Defaults to PORT + 1 (e.g. 3001 when PORT=3000).
#   Set explicitly if you want a specific port (e.g. behind a reverse proxy).
# WEB_PORT=3001

# NODE_ENV: set to "production" for production deployments.
NODE_ENV=production

# ── Optional: override config.json secrets via env vars ───────
# These take precedence over what is stored in config.json.
# Useful for Docker / CI / secrets managers.
#
# LOCAL_API_KEY=your-secret-local-key
# ACTIVE_PROVIDER_ID=swiftrouter
# SWIFTROUTER_API_KEY=sk-xxxxxxx
# AGENTROUTER_API_KEY=sk-xxxxxxx

# ── Google OAuth ────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5174/auth/google/callback

# ── General Settings ────────────────────────────────
SESSION_SECRET=a-secure-random-string
ADMIN_EMAILS=admin@example.com


# ── Proxy server bind settings ────────────────────────────────
# HOST: interface to bind the proxy server on.
#   Use 127.0.0.1 for local-only access (default).
HOST=127.0.0.1

# PORT: port for the AI proxy (OpenAI-compatible /v1 endpoint).
# The dashboard API/auth server runs on PORT + 1.
PORT=3000

# ── Optional: override config.json secrets via env vars ───────
# These take precedence over what is stored in config.json.
#
# LOCAL_API_KEY=your-secret-local-key
# ACTIVE_PROVIDER_ID=swiftrouter
# SWIFTROUTER_API_KEY=sk-xxxxxxx
# AGENTROUTER_API_KEY=sk-xxxxxxx

# ── Google OAuth ────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5174/auth/google/callback

# ── General Settings ────────────────────────────────
SESSION_SECRET=a-secure-random-string
ADMIN_EMAILS=admin@example.com
